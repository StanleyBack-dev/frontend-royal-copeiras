#!/bin/sh

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
REPO_ROOT="$(CDPATH= cd -- "$SCRIPT_DIR/.." && pwd)"

cd "$REPO_ROOT" || exit 1

echo "[pre-push] Running prettier and lint checks..."
npm run prepush:check
status=$?

if [ "$status" -ne 0 ]; then
  echo "[pre-push] Push blocked. Fix local errors and try again."
  exit "$status"
fi

echo "[pre-push] Checks passed."